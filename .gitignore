# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ─── Environment files (never commit secrets) ─────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─── Compiled output ──────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*

# ─── Database ─────────────────────────────────────────────────────────────────
*.sqlite
*.db
drizzle/

# ─── Coverage ─────────────────────────────────────────────────────────────────
/coverage/

# ─── IDEs and editors ─────────────────────────────────────────────────────────
/.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/extensions.json

# ─── Misc ─────────────────────────────────────────────────────────────────────
/.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings/

# ─── System files ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Replit ───────────────────────────────────────────────────────────────────
.cache/
.local/

# ─── Cursor / GitHub auto-generated ──────────────────────────────────────────
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
